---
import Button from '~/components/ui/Button.astro';
import type { CallToAction } from '~/types';

export interface Props {
  id?: string;
  title?: string;
  subtitle?: string;
  actions?: CallToAction[];
}

const { id, title, subtitle, actions = [] } = Astro.props;
---

<section {...id ? { id } : {}} class="relative overflow-hidden">
  <div class="relative mx-auto max-w-7xl px-4 md:px-6 py-20 md:py-28 lg:py-36 text-center">
    {
      title && (
        <h1 class="mx-auto max-w-4xl font-bold font-heading text-4xl md:text-5xl lg:text-6xl tracking-tight leading-[1.1]">
          <Fragment set:html={title} />
        </h1>
      )
    }
    {
      subtitle && (
        <p class="mx-auto max-w-2xl mt-6 text-lg md:text-xl text-muted">
          <Fragment set:html={subtitle} />
        </p>
      )
    }
    {
      actions?.length ? (
        <div class="mt-10 flex flex-wrap items-center justify-center gap-4">
          {actions.map((action) => (
            <Button {...action} />
          ))}
        </div>
      ) : null
    }
  </div>
</section>

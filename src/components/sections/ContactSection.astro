---
import { Icon } from 'astro-icon/components';
import WidgetWrapper from '~/components/ui/WidgetWrapper.astro';
import Headline from '~/components/ui/Headline.astro';

interface SelectOption {
  value: string;
  label: string;
}

interface FormInput {
  type?: string;
  name: string;
  label?: string;
  autocomplete?: string;
  placeholder?: string;
  required?: boolean;
  options?: string[];
  fullSpan?: boolean;
}

type InputType =
  | 'text'
  | 'email'
  | 'tel'
  | 'number'
  | 'password'
  | 'url'
  | 'search'
  | 'date'
  | 'datetime-local'
  | 'time'
  | 'week'
  | 'month'
  | 'hidden'
  | 'checkbox'
  | 'radio'
  | 'range'
  | 'color'
  | 'file'
  | 'submit'
  | 'reset'
  | 'button'
  | 'image';

interface FormTextarea {
  name: string;
  label?: string;
  placeholder?: string;
  rows?: number;
  fullSpan?: boolean;
}

interface ContactMethod {
  label?: string;
  value?: string;
  href?: string;
  icon?: string;
}

export interface Props {
  id?: string;
  tagline?: string;
  title?: string;
  subtitle?: string;
  inputs?: FormInput[];
  textarea?: FormTextarea;
  button?: string;
  disclaimer?: string;
  contactMethods?: ContactMethod[];
}

const {
  id,
  tagline,
  title,
  subtitle,
  inputs = [],
  textarea,
  button = 'Send',
  disclaimer,
  contactMethods = [],
} = Astro.props;

const isSelect = (input: FormInput) => input.type === 'select' || (input.options?.length ?? 0) > 0;

const toOption = (opt: string): SelectOption => ({ value: opt, label: opt });
---

<WidgetWrapper id={id}>
  <Headline tagline={tagline} title={title} subtitle={subtitle} />

  {
    contactMethods?.length ? (
      <div class="mt-8 grid gap-4 sm:grid-cols-2 max-w-xl mx-auto">
        {contactMethods.map((method) => (
          <a
            href={method.href}
            class="flex items-center gap-3 p-4 rounded-lg border border-gray-200 dark:border-slate-800 bg-white dark:bg-slate-900 hover:border-primary hover:bg-primary/5 transition"
          >
            {method.icon && (
              <span class="inline-flex items-center justify-center w-10 h-10 rounded-lg bg-primary/10 text-primary shrink-0">
                <Icon name={method.icon} class="w-5 h-5" />
              </span>
            )}
            <span class="min-w-0">
              {method.label && <span class="block text-xs uppercase tracking-wide text-muted">{method.label}</span>}
              <span class="block font-medium text-page truncate">{method.value}</span>
            </span>
          </a>
        ))}
      </div>
    ) : null
  }

  <form
    name="contact"
    method="POST"
    data-netlify="true"
    netlify-honeypot="bot-field"
    action="/?submitted=true"
    class="perpterps-form mx-auto mt-8 max-w-3xl grid md:grid-cols-2 gap-5 p-6 md:p-10 border-2"
  >
    <input type="hidden" name="form-name" value="contact" />
    <p class="hidden">
      <label>Don't fill this out if you're human: <input name="bot-field" /></label>
    </p>

    {
      inputs.map((input) => {
        const colSpan = input.fullSpan ? 'md:col-span-2' : '';
        return (
          <div class={colSpan}>
            {input.label && (
              <label class="pf-label" for={input.name}>
                {input.label}
              </label>
            )}
            {isSelect(input) ? (
              <select id={input.name} name={input.name} class="pf-select" required={input.required}>
                {(input.options ?? []).map((opt) => {
                  const o = toOption(opt);
                  return <option value={o.value}>{o.label}</option>;
                })}
              </select>
            ) : (
              <input
                type={(input.type as InputType) || 'text'}
                name={input.name}
                id={input.name}
                autocomplete={input.autocomplete}
                placeholder={input.placeholder}
                required={input.required}
                class="pf-input"
              />
            )}
          </div>
        );
      })
    }

    {
      textarea && (
        <div class={textarea.fullSpan === false ? '' : 'md:col-span-2'}>
          {textarea.label && (
            <label class="pf-label" for={textarea.name}>
              {textarea.label}
            </label>
          )}
          <textarea
            id={textarea.name}
            name={textarea.name}
            rows={textarea.rows ?? 4}
            placeholder={textarea.placeholder}
            class="pf-textarea"
          />
        </div>
      )
    }

    {
      (disclaimer || button) && (
        <div class="md:col-span-2 flex justify-between items-center flex-wrap gap-4 pt-2">
          {disclaimer && <p class="text-xs max-w-xs text-cream-dim leading-relaxed">{disclaimer}</p>}
          {button && (
            <button type="submit" class="pf-cta">
              {button}
            </button>
          )}
        </div>
      )
    }
  </form>
</WidgetWrapper>

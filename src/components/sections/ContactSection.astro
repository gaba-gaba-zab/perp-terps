---
import { Icon } from 'astro-icon/components';
import WidgetWrapper from '~/components/ui/WidgetWrapper.astro';
import Headline from '~/components/ui/Headline.astro';

interface FormInput {
  type?: string;
  name: string;
  label?: string;
  autocomplete?: string;
  placeholder?: string;
  required?: boolean;
}

type InputType =
  | 'text'
  | 'email'
  | 'tel'
  | 'number'
  | 'password'
  | 'url'
  | 'search'
  | 'date'
  | 'datetime-local'
  | 'time'
  | 'week'
  | 'month'
  | 'hidden'
  | 'checkbox'
  | 'radio'
  | 'range'
  | 'color'
  | 'file'
  | 'submit'
  | 'reset'
  | 'button'
  | 'image';

interface FormTextarea {
  name: string;
  label?: string;
  placeholder?: string;
  rows?: number;
}

interface ContactMethod {
  label?: string;
  value?: string;
  href?: string;
  icon?: string;
}

export interface Props {
  id?: string;
  tagline?: string;
  title?: string;
  subtitle?: string;
  inputs?: FormInput[];
  textarea?: FormTextarea;
  button?: string;
  contactMethods?: ContactMethod[];
}

const {
  id,
  tagline,
  title,
  subtitle,
  inputs = [],
  textarea,
  button = 'Send',
  contactMethods = [],
} = Astro.props;

const fieldClass =
  'py-3 px-4 block w-full text-md rounded-lg border border-gray-200 dark:border-gray-700 bg-white dark:bg-slate-900';
---

<WidgetWrapper id={id}>
  <Headline tagline={tagline} title={title} subtitle={subtitle} />

  {
    contactMethods?.length ? (
      <div class="mt-8 grid gap-4 sm:grid-cols-2 max-w-xl mx-auto">
        {contactMethods.map((method) => (
          <a
            href={method.href}
            class="flex items-center gap-3 p-4 rounded-lg border border-gray-200 dark:border-slate-800 bg-white dark:bg-slate-900 hover:border-primary hover:bg-primary/5 transition"
          >
            {method.icon && (
              <span class="inline-flex items-center justify-center w-10 h-10 rounded-lg bg-primary/10 text-primary shrink-0">
                <Icon name={method.icon} class="w-5 h-5" />
              </span>
            )}
            <span class="min-w-0">
              {method.label && (
                <span class="block text-xs uppercase tracking-wide text-muted">{method.label}</span>
              )}
              <span class="block font-medium text-page truncate">{method.value}</span>
            </span>
          </a>
        ))}
      </div>
    ) : null
  }

  <form
    name="contact"
    method="POST"
    data-netlify="true"
    netlify-honeypot="bot-field"
    action="/?submitted=true"
    class="mx-auto max-w-xl rounded-xl border border-gray-200 dark:border-slate-800 bg-white dark:bg-slate-900 shadow-sm p-6 md:p-8"
  >
    <input type="hidden" name="form-name" value="contact" />
    <p class="hidden">
      <label>Don't fill this out if you're human: <input name="bot-field" /></label>
    </p>

    {
      inputs.map((input) => (
        <div class="mb-5">
          {input.label && (
            <label for={input.name} class="block text-sm font-medium mb-1">
              {input.label}
            </label>
          )}
          <input
            type={input.type as InputType}
            name={input.name}
            id={input.name}
            autocomplete={input.autocomplete}
            placeholder={input.placeholder}
            required={input.required}
            class={fieldClass}
          />
        </div>
      ))
    }

    {
      textarea && (
        <div class="mb-5">
          {textarea.label && (
            <label for={textarea.name} class="block text-sm font-medium mb-1">
              {textarea.label}
            </label>
          )}
          <textarea
            id={textarea.name}
            name={textarea.name}
            rows={textarea.rows ?? 4}
            placeholder={textarea.placeholder}
            class={fieldClass}
          />
        </div>
      )
    }

    <div class="mt-2">
      <button type="submit" class="btn-primary w-full">{button}</button>
    </div>
  </form>
</WidgetWrapper>

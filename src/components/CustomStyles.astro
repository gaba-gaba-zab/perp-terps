---
import '@fontsource-variable/inter';

// 'DM Sans'
// Nunito
// Dosis
// Outfit
// Roboto
// Literata
// 'IBM Plex Sans'
// Karla
// Poppins
// 'Fira Sans'
// 'Libre Franklin'
// Inconsolata
// Raleway
// Oswald
// 'Space Grotesk'
// Urbanist
---

<style is:inline>
  :root {
    --aw-font-sans: 'Inter Variable';
    --aw-font-serif: 'Inter Variable';
    --aw-font-heading: 'Inter Variable';

    /* Named palette (mode-invariant) */
    --aw-color-forest-deep: rgb(10 24 16);
    --aw-color-moss: rgb(45 74 45);
    --aw-color-chartreuse: rgb(200 224 53);
    --aw-color-chartreuse-bright: rgb(220 245 74);
    --aw-color-amber-trich: rgb(230 168 23);
    --aw-color-amber-bright: rgb(245 197 66);
    --aw-color-soil-light: rgb(107 86 64);
    --aw-color-cream: rgb(236 227 200);
    --aw-color-cream-dim: rgb(197 189 160);
    --aw-color-ink: rgb(5 10 7);

    /* Semantic aliases — light mode */
    --aw-color-primary: var(--aw-color-forest-deep);
    --aw-color-secondary: var(--aw-color-moss);
    --aw-color-accent: var(--aw-color-chartreuse);

    --aw-color-text-heading: var(--aw-color-ink);
    --aw-color-text-default: rgb(16 16 16);
    --aw-color-text-muted: rgb(16 16 16 / 66%);
    --aw-color-bg-page: var(--aw-color-cream);

    --aw-color-bg-page-dark: var(--aw-color-ink);

    /* Matched to the banner PNG's baked-in flat-bg, not a brand token */
    --aw-color-banner-bg: rgb(40 74 31);

    ::selection {
      background-color: rgb(200 224 53 / 30%);
    }
  }

  .dark {
    --aw-font-sans: 'Inter Variable';
    --aw-font-serif: 'Inter Variable';
    --aw-font-heading: 'Inter Variable';

    /* Semantic aliases — dark mode (brighter variants for contrast on ink) */
    --aw-color-primary: var(--aw-color-moss);
    --aw-color-secondary: var(--aw-color-soil-light);
    --aw-color-accent: var(--aw-color-chartreuse-bright);

    --aw-color-text-heading: var(--aw-color-cream);
    --aw-color-text-default: var(--aw-color-cream-dim);
    --aw-color-text-muted: rgb(197 189 160 / 66%);
    --aw-color-bg-page: var(--aw-color-ink);

    /* Matched to the banner PNG's baked-in flat-bg, not a brand token */
    --aw-color-banner-bg: rgb(40 74 31);

    ::selection {
      background-color: rgb(220 245 74 / 30%);
      color: snow;
    }
  }
</style>

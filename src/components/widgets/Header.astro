---
import { Image } from 'astro:assets';
import { Icon } from 'astro-icon/components';
import ToggleTheme from '~/components/common/ToggleTheme.astro';
import ToggleMenu from '~/components/common/ToggleMenu.astro';
import Button from '~/components/ui/Button.astro';

import { trimSlash, getAsset } from '~/utils/permalinks';
import { SITE } from 'astrowind:config';
import bannerImg from '~/assets/images/perpterps_banner.png';
import type { CallToAction } from '~/types';

interface Link {
  text?: string;
  href?: string;
  ariaLabel?: string;
  icon?: string;
}

interface MenuLink extends Link {
  links?: Array<MenuLink>;
}

export interface Props {
  id?: string;
  links?: Array<MenuLink>;
  actions?: Array<CallToAction>;
  isSticky?: boolean;
  isDark?: boolean;
  isFullWidth?: boolean;
  showToggleTheme?: boolean;
  showRssFeed?: boolean;
  position?: string;
}

const {
  id = 'header',
  links = [],
  actions = [],
  isSticky = false,
  isDark = false,
  showToggleTheme = false,
  showRssFeed = false,
} = Astro.props;

const currentPath = `/${trimSlash(new URL(Astro.url).pathname)}`;
---

<header
  id={id}
  class:list={['group sticky top-0 z-40 w-full bg-page', { dark: isDark }]}
  {...isSticky ? { 'data-aw-sticky-header': true } : {}}
>
  <div class="absolute inset-0 overflow-hidden">
    <Image
      src={bannerImg}
      alt={SITE?.name ?? 'Perpetual Terpsters'}
      class="w-full h-full object-cover md:object-contain"
      widths={[400, 800, 1200, 1920]}
      sizes="100vw"
    />
  </div>

  <div
    class:list={[
      'relative h-32 md:h-40 group-[.scroll]:h-16 md:group-[.scroll]:h-16 transition-[height] duration-300 ease-in-out flex justify-between items-center px-4 md:px-6',
    ]}
  >
    <div class="flex items-center">
      <ToggleMenu />
    </div>

    <div data-aw-header-actions class="flex items-center gap-3">
      <div class="flex">
        {showToggleTheme && <ToggleTheme iconClass="w-6 h-6 md:w-5 md:h-5" />}
        {
          showRssFeed && (
            <a
              class="text-muted dark:text-gray-400 hover:bg-gray-100 dark:hover:bg-gray-700 focus:outline-none focus:ring-4 focus:ring-gray-200 dark:focus:ring-gray-700 rounded-lg text-sm p-2.5 inline-flex items-center"
              aria-label="RSS Feed"
              href={getAsset('/rss.xml')}
            >
              <Icon name="tabler:rss" class="w-5 h-5" />
            </a>
          )
        }
      </div>
      {
        actions?.length ? (
          <span class="ml-2 rtl:ml-0 rtl:mr-2">
            {actions.map((btnProps) => (
              <Button {...btnProps} class="ml-2 py-2.5 px-5.5 md:px-6 font-semibold shadow-none text-sm w-auto" />
            ))}
          </span>
        ) : null
      }
    </div>
  </div>

  <nav
    data-aw-slide-menu
    aria-label="Main navigation"
    class="fixed inset-y-0 left-0 w-80 max-w-[85vw] bg-page shadow-2xl -translate-x-full transition-transform duration-300 ease-in-out group-[.expanded]:translate-x-0 z-50 overflow-y-auto"
  >
    <ul class="flex flex-col p-6 gap-2 text-default">
      {
        links.map(({ text, href }) => (
          <li>
            <a
              class:list={[
                'block py-3 text-lg font-medium hover:text-link dark:hover:text-white',
                { 'aw-link-active': href === currentPath },
              ]}
              href={href}
            >
              {text}
            </a>
          </li>
        ))
      }
    </ul>
  </nav>

  <div
    data-aw-menu-scrim
    class="fixed inset-0 bg-black/50 opacity-0 pointer-events-none transition-opacity duration-300 group-[.expanded]:opacity-100 group-[.expanded]:pointer-events-auto z-40"
  >
  </div>
</header>
